# ============================================================
# LedgerRAG configuration
# Copy to .env and adjust. The platform is model- and
# hardware-agnostic (constraint C3): every model role below is
# mapped by the deploying engineer to a concrete endpoint.
# Nested keys use "__" (pydantic-settings nested delimiter).
# ============================================================

# --- Infrastructure -----------------------------------------
LEDGERRAG_DATABASE_URL=postgresql+psycopg://ledgerrag:ledgerrag@localhost:5432/ledgerrag
LEDGERRAG_REDIS_URL=redis://localhost:6379/0
LEDGERRAG_QDRANT_URL=http://localhost:6333

# Object storage: "minio" or "local"
LEDGERRAG_OBJECT_STORE__BACKEND=minio
LEDGERRAG_OBJECT_STORE__ENDPOINT=localhost:9000
LEDGERRAG_OBJECT_STORE__ACCESS_KEY=ledgerrag
LEDGERRAG_OBJECT_STORE__SECRET_KEY=ledgerrag-secret
LEDGERRAG_OBJECT_STORE__BUCKET=ledgerrag
LEDGERRAG_OBJECT_STORE__SECURE=false
# For BACKEND=local:
# LEDGERRAG_OBJECT_STORE__ROOT=./data/objects

# --- Model roles (constraint C3: no hardcoded models) --------
# provider: ollama | openai_compat | disabled
# In local-only deployments (constraint C1) every base_url must
# point at infrastructure you control; no external calls happen
# in the data path.

# parser (VLM) - used at ingestion for tables/scans (Phase 2+)
# NOTE: for qwen3-vl use the -instruct tag; the default tag is a thinking
# model that returns empty output through /api/chat (spike campaign finding).
LEDGERRAG_MODELS__PARSER__PROVIDER=ollama
LEDGERRAG_MODELS__PARSER__BASE_URL=http://localhost:11434
LEDGERRAG_MODELS__PARSER__MODEL_NAME=qwen3-vl:8b-instruct

# embedder - used for indexing and querying
LEDGERRAG_MODELS__EMBEDDER__PROVIDER=ollama
LEDGERRAG_MODELS__EMBEDDER__BASE_URL=http://localhost:11434
LEDGERRAG_MODELS__EMBEDDER__MODEL_NAME=bge-m3
# Must match the embedder output dimension (bge-m3 = 1024)
LEDGERRAG_EMBEDDING_DIM=1024

# chat (LLM) - answer generation, summaries, multi-KB routing.
# qwen2.5:14b (the instruct default, NOT the Coder variant) is the config the
# answer-quality gate passed with; a smaller model drifts language + misreads
# columns (see README Phase 4).
LEDGERRAG_MODELS__CHAT__PROVIDER=ollama
LEDGERRAG_MODELS__CHAT__BASE_URL=http://localhost:11434
LEDGERRAG_MODELS__CHAT__MODEL_NAME=qwen2.5:14b

# reranker - "disabled" = document-diversified fallback (fine to start). To
# enable, point at an OpenAI-compatible /rerank endpoint (vLLM or the opt-in
# TEI service): provider=openai_compat, base_url=http://host:PORT,
# model_name=bge-reranker-v2-m3. It closes the "right doc, wrong rank" misses.
LEDGERRAG_MODELS__RERANKER__PROVIDER=disabled
LEDGERRAG_MODELS__RERANKER__BASE_URL=
LEDGERRAG_MODELS__RERANKER__MODEL_NAME=

# Optional per-endpoint API key (openai_compat providers)
# LEDGERRAG_MODELS__CHAT__API_KEY=sk-...

# --- Pipeline tuning ------------------------------------------
LEDGERRAG_CHUNK_TARGET_TOKENS=500
LEDGERRAG_CHUNK_OVERLAP_RATIO=0.10
LEDGERRAG_RETRIEVE_TOP_K=12
# Answer-number verification (Phase 4). Default ON: it is the honesty net for a
# numbers tool — every number in an answer is checked against the sources.
LEDGERRAG_VERIFICATION_ENABLED=true

# --- Frontend --------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
